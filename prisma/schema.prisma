generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                  String    @id @default(cuid())
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now())
  user_id             String
  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?
  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt
  name       String?   @db.VarChar(255)

  // Basic Info (Common for both)
  first_name    String?   @db.VarChar(255)
  last_name     String?   @db.VarChar(255)
  email         String?   @unique
  password      String?   @db.VarChar(255)
  phone_number  String?
  gender        String?
  date_of_birth DateTime? @db.Date
  address       String?
  avatar        String?
  type          UserType  @default(CLIENT)

  //client specific fields 
  service_plan      ServicePlan? @default(BASIC)
  assigned_agent_id String?

  //agent specific fields 
  certification_body      String?      @map("certification_body")
  certification_number    String?      @map("certification_number")
  years_of_experience     String?      @map("years_of_experience")
  specialisation          String?      @map("specialisation")
  professional_bio        String?      @map("professional_bio") @db.Text
  certificate_url         Attachment[] @relation("certificate")
  preferred_working_hours String?      @map("preferred_working_hours")
  max_clients_per_month   Int?         @default(20) @map("max_clients_per_month")

  // Other Existing Fields
  username              String?  @unique
  domain                String?  @unique
  balance               Decimal? @default(0.0) @db.Decimal(10, 2)
  is_two_factor_enabled Int?     @default(0)
  fcm_token             String?
  device_type           String?

  stripe_connect_id     String? // Stripe Connected Account ID
  stripe_balance        Json? // Stripe Balance Info (JSON)
  stripe_payout_enabled Boolean? @default(false)
  billing_id            String? // Stripe Customer ID
  billing_email         String? // Stripe Customer Email

  email_verified_at DateTime?
  approved_at       DateTime?
  two_factor_secret String?
  points            Int?      @default(0)
  availability      Boolean?  @default(true)

  // Relations
  sentMessages          Message[]            @relation("messageSender")
  receivedNotifications Notification[]       @relation("notificationReceiver")
  sentNotifications     Notification[]       @relation("notificationSender")
  participants          Participant[]        @relation("participantUser")
  accounts              Account[]
  comments              Comment[]
  feedbacks_given       Feedback[]           @relation("FeedbackAuthor")
  liveStreams           live_streams[]
  payment_transactions  PaymentTransaction[]
  postCommunities       PostCommunity[]
  postLikes             PostLike[]
  created_requests      Request[]            @relation("SeekerRequests")
  accepted_tasks        Request[]            @relation("VolunteerTasks")
  role_users            RoleUser[]
  ucodes                Ucode[]
  user_payment_methods  UserPaymentMethod[]
  // Named relations for fixing the ambiguous error
  willsAsAgent          Will[]               @relation("AgentWills")
  willsAsClient         Will[]               @relation("ClientWills")
  assetsAsAgent         Asset[]              @relation("AgentAssets")
  assetsAsClient        Asset[]              @relation("ClientAssets")

  @@map("users")
}

model Ucode {
  id          String    @id @default(cuid())
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
  status      Int?      @default(1) @db.SmallInt
  user_id     String?
  token       String?
  email       String?
  expired_at  DateTime?
  verified_at DateTime?
  user        User?     @relation(fields: [user_id], references: [id])

  @@map("ucodes")
}

model PostCommunity {
  id           String     @id @default(uuid())
  author_id    String
  title        String?
  content      String?
  image_url    String?
  location_tag String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  comments     Comment[]
  user         User       @relation(fields: [author_id], references: [id])
  likes        PostLike[]

  @@map("post_communities")
}

model Comment {
  id         String        @id @default(uuid())
  post_id    String
  author_id  String
  content    String
  created_at DateTime      @default(now())
  parent_id  String?
  user       User          @relation(fields: [author_id], references: [id])
  parent     Comment?      @relation("CommentReplies", fields: [parent_id], references: [id])
  replies    Comment[]     @relation("CommentReplies")
  post       PostCommunity @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("comments")
}

model PostLike {
  id         String        @id @default(uuid())
  post_id    String
  user_id    String
  created_at DateTime      @default(now())
  post       PostCommunity @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [user_id], references: [id])

  @@unique([post_id, user_id])
  @@map("post_likes")
}

model Request {
  id                 String          @id @default(uuid())
  title              String
  description        String
  category           RequestCategory
  location           String
  estimated_duration String?
  urgency_level      UrgencyLevel    @default(MEDIUM)
  skills_needed      String[]
  status             RequestStatus   @default(PENDING)
  seeker_id          String
  volunteer_id       String?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  attachments        Attachment[]    @relation("RequestAttachments")
  feedbacks          Feedback[]
  seeker             User            @relation("SeekerRequests", fields: [seeker_id], references: [id])
  volunteer          User?           @relation("VolunteerTasks", fields: [volunteer_id], references: [id])

  @@map("requests")
}

model Feedback {
  id          String   @id @default(uuid())
  comment     String?
  request_id  String
  user_id     String
  created_at  DateTime @default(now())
  rating_type Boolean?
  request     Request  @relation(fields: [request_id], references: [id])
  user        User     @relation("FeedbackAuthor", fields: [user_id], references: [id])

  @@map("feedbacks")
}

model Conversation {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  participants Participant[]
}

model Participant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  role           String?      @default("participant")
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation("participantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  text           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  status         MessageStatus @default(PENDING)
  senderId       String
  conversationId String
  attachments    String[]
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model NotificationEvent {
  id            String         @id @default(uuid())
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  deleted_at    DateTime?
  status        Int?           @default(1) @db.SmallInt
  type          String?
  text          String?
  notifications Notification[]
}

model Notification {
  id                    String             @id @default(cuid())
  created_at            DateTime           @default(now())
  updated_at            DateTime           @default(now()) @updatedAt
  deleted_at            DateTime?
  read_at               DateTime?
  status                Int?               @default(1) @db.SmallInt
  sender_id             String?
  receiver_id           String?
  notification_event_id String?
  entity_id             String?
  latest_news           Boolean            @default(true)
  sign_of_disaster      Boolean            @default(true)
  message_news          Boolean            @default(true)
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])
  receiver              User?              @relation("notificationReceiver", fields: [receiver_id], references: [id])
  sender                User?              @relation("notificationSender", fields: [sender_id], references: [id])
}

model video_calls {
  id          String    @id @default(uuid())
  room_name   String    @unique
  caller_id   String
  receiver_id String
  status      String    @default("pending")
  started_at  DateTime  @default(now())
  ended_at    DateTime?
  duration    Int?

  @@index([caller_id, receiver_id])
}

model live_streams {
  id            String    @id @default(uuid())
  room_name     String    @unique
  host_id       String
  title         String?
  is_active     Boolean   @default(true)
  recording_url String? // Auto-record houar por S3 link ekhane thakbe
  status        String    @default("streaming") // streaming, completed, failed
  created_at    DateTime  @default(now())
  ended_at      DateTime?

  host User @relation(fields: [host_id], references: [id])
}

model Role {
  id               String           @id @default(cuid())
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now())
  deleted_at       DateTime?
  status           Int?             @default(1) @db.SmallInt
  title            String?
  name             String?
  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]     @relation("PermissionToRole")

  @@map("roles")
}

model Permission {
  id               String           @id @default(cuid())
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now())
  deleted_at       DateTime?
  status           Int?             @default(1) @db.SmallInt
  title            String?
  action           String?
  subject          String?
  conditions       String?
  fields           String?
  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at    DateTime   @default(now())
  updated_at    DateTime   @default(now())
  permission_id String
  role_id       String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  role_id    String
  user_id    String
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([role_id, user_id])
  @@map("role_users")
}

model UserPaymentMethod {
  id                String    @id @default(cuid())
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now())
  deleted_at        DateTime?
  user_id           String?
  payment_method_id String?
  checkout_id       String?
  user              User?     @relation(fields: [user_id], references: [id])

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id               String    @id @default(cuid())
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
  deleted_at       DateTime?
  store_id         String?
  user_id          String?
  order_id         String?
  type             String?   @default("order")
  withdraw_via     String?   @default("wallet")
  provider         String?
  reference_number String?
  status           String?   @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?
  user             User?     @relation(fields: [user_id], references: [id])

  @@map("payment_transactions")
}

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt
  sort_order Int?      @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id           String    @id @default(cuid())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  deleted_at   DateTime?
  first_name   String?
  last_name    String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

model Attachment {
  id         String            @id @default(cuid())
  created_at DateTime          @default(now())
  updated_at DateTime          @default(now())
  deleted_at DateTime?
  name       String?
  type       String?
  path       String?
  request_id String?
  request    Request?          @relation("RequestAttachments", fields: [request_id], references: [id], onDelete: Cascade)
  users      User[]            @relation("certificate")
  bequests   SpecificBequest[] @relation("SpecificBequestAttachments")

  @@map("attachments")
}

enum UserType {
  ADMIN
  CLIENT
  AGENT
  EDITOR
  MAID
}

enum ServicePlan {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum RequestStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum RequestCategory {
  HURRICANE_PREPARATION
  DURING_STORM
  RECOVERY_CLEANUP
  EMERGENCY_NON_911
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  PENDING
}

enum PlanType {
  STANDARD
  PREMIUM
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
}

enum RelationshipType {
  SPOUSE_PARTNER
  CHILD
  SIBLING
  PARENT
  FRIEND
  OTHER
}

// will model ......................................

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  CIVIL_PARTNERSHIP
  SEPARATED

  @@map("marital_status")
}

enum BeneficiaryType {
  PRIMARY
  RESIDUARY

  @@map("beneficiary_type")
}

enum WillStatus {
  DRAFT
  PENDING_REVIEW
  COMPLETED
  REVOKED

  @@map("will_status")
}

model Will {
  id        String     @id @default(cuid())
  agent_id  String     @map("agent_id")
  client_id String     @map("client_id")
  status    WillStatus @default(DRAFT)

  // Step 1A: Testator Information
  testatorFullName    String        @map("testator_full_name") @db.VarChar(255)
  testatorDob         DateTime      @map("testator_dob") @db.Date
  nationalInsuranceNo String?       @map("national_insurance_no") @db.VarChar(50)
  maritalStatus       MaritalStatus @map("marital_status")
  currentAddress      String        @map("current_address") @db.Text
  nationality         String        @map("nationality") @db.VarChar(100)
  occupation          String?       @map("occupation") @db.VarChar(150)
  previouslyMadeWill  Boolean       @default(false) @map("previously_made_will")

  // Step 1B & Step 6 Checklist Flags
  hasImmediateDependants Boolean @default(false) @map("has_immediate_dependants")
  hasChildren            Boolean @default(false) @map("has_children")
  hasExclusions          Boolean @default(false) @map("has_exclusions")

  // Step 1: Agent Confirmations
  agentConfirmSoundMind Boolean @default(false) @map("agent_confirm_sound_mind")
  agentConfirmVerified  Boolean @default(false) @map("agent_confirm_verified")

  // Step 3: Executor Powers
  powerToSellProperty Boolean @default(false) @map("power_to_sell_property")

  // Step 6: Final Checklist Verification Timestamps
  testatorInfoCorrect  Boolean @default(false) @map("testator_info_correct")
  sharesTotalAllocated Boolean @default(false) @map("shares_total_allocated")
  executorsCorrect     Boolean @default(false) @map("executors_correct")
  exclusionsReviewed   Boolean @default(false) @map("exclusions_reviewed")
  childrenConfirmed    Boolean @default(false) @map("children_confirmed")
  sectionsApproved     Boolean @default(false) @map("sections_approved")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent            User              @relation("AgentWills", fields: [agent_id], references: [id], onDelete: Cascade)
  client           User              @relation("ClientWills", fields: [client_id], references: [id], onDelete: Cascade)
  dependants       Dependant[]
  beneficiaries    Beneficiary[]
  executors        Executor[]
  exclusions       Exclusion[]
  specificBequests SpecificBequest[]

  @@index([agent_id])
  @@index([client_id])
  @@index([status])
  @@map("wills")
}

model Dependant {
  id           String           @id @default(uuid())
  willId       String           @map("will_id")
  fullName     String           @map("full_name") @db.VarChar(255)
  relationship RelationshipType
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  will Will @relation(fields: [willId], references: [id], onDelete: Cascade)

  @@index([willId])
  @@map("dependants")
}

model Beneficiary {
  id              String           @id @default(uuid())
  willId          String           @map("will_id")
  type            BeneficiaryType
  fullName        String           @map("full_name") @db.VarChar(255)
  relationship    RelationshipType
  dob             DateTime?        @map("dob") @db.Date
  sharePercentage Decimal          @map("share_percentage") @db.Decimal(5, 2)
  contactAddress  String?          @map("contact_address") @db.Text
  isMinor         Boolean          @default(false) @map("is_minor")
  specificBequest String?          @map("specific_bequest") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  will             Will              @relation(fields: [willId], references: [id], onDelete: Cascade)
  specificBequests SpecificBequest[]

  @@index([willId])
  @@map("beneficiaries")
}

model Executor {
  id           String           @id @default(uuid())
  willId       String           @map("will_id")
  priority     Int              @default(1) // 1 = Primary, 2 = Secondary, etc.
  firstName    String           @map("first_name") @db.VarChar(100)
  relationship RelationshipType
  email        String           @db.VarChar(255)
  phone        String           @db.VarChar(50)
  address      String           @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  will Will @relation(fields: [willId], references: [id], onDelete: Cascade)

  @@index([willId])
  @@map("executors")
}

model Exclusion {
  id           String           @id @default(uuid())
  willId       String           @map("will_id")
  fullName     String           @map("full_name") @db.VarChar(255)
  relationship RelationshipType
  reason       String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  will Will @relation(fields: [willId], references: [id], onDelete: Cascade)

  @@index([willId])
  @@map("exclusions")
}

enum ItemCategory {
  RESIDENTIAL_PROPERTY
  COMMERCIAL_PROPERTY
  LAND_PLOTS
  CASH_BANK_ACCOUNT
  STOCKS_SHARES
  MUTUAL_FUNDS_BONDS
  RETIREMENT_PENSIONS
  LIFE_INSURANCE
  JEWELLERY_PRECIOUS_METALS
  ART_AND_ANTIQUES
  COLLECTIBLES
  VEHICLES
  ELECTRONICS_GADGETS
  FURNITURE_HOME_APPLIANCES
  CLOTHING_ACCESSORIES
  DIGITAL_ASSETS
  INTELLECTUAL_PROPERTY
  BUSINESS_INTEREST_EQUITY
  PETS_LIVESTOCK
  MEMORABILIA_SENTIMENTAL
  OTHER

  @@map("item_category")
}

model SpecificBequest {
  id               String        @id @default(uuid())
  agent_id         String        @map("agent_id")
  client_id        String        @map("client_id")
  item_category    ItemCategory?
  estimated_value  Decimal?      @map("estimated_value") @db.Decimal(12, 2)
  item_name        String        @map("item_name") @db.VarChar(255)
  full_description String        @map("full_description") @db.Text
  location_storage String?       @map("location_storage") @db.VarChar(255)
  serial_reference String?       @map("serial_reference") @db.VarChar(100)
  attachments      Attachment[]  @relation("SpecificBequestAttachments")
  beneficiary_id   String        @map("beneficiary_id")

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations
  beneficiary Beneficiary? @relation(fields: [beneficiary_id], references: [id], onDelete: SetNull)
  will        Will?        @relation(fields: [willId], references: [id])
  willId      String?

  @@index([agent_id])
  @@index([client_id])
  @@index([beneficiary_id])
  @@map("specific_bequests")
}

enum AssetType {
  PROPERTY
  FINANCIAL
  VEHICLES
  VALUABLES
  DEBTS

  @@map("asset_type")
}

model Asset {
  id String @id @default(uuid())

  agent_id   String    @map("agent_id")
  client_id  String    @map("client_id")
  asset_type AssetType @map("asset_type")

  // Real Estate & Property Fields
  property_address     String? @map("property_address") @db.Text
  ownership_type       String? @map("ownership_type")
  property_type        String? @map("property_type") @db.VarChar(100) // e.g., Residential, Commercial
  estimated_value      Decimal @default(0.00) @map("estimated_value") @db.Decimal(12, 2)
  outstanding_mortgage Decimal @default(0.00) @map("outstanding_mortgage") @db.Decimal(12, 2)
  additional_notes     String? @map("additional_notes") @db.Text

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations matching your explicit system rules
  agent  User @relation("AgentAssets", fields: [agent_id], references: [id], onDelete: Cascade)
  client User @relation("ClientAssets", fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([agent_id])
  @@index([asset_type])
  @@map("assets")
}
